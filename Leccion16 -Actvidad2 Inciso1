using System;

internal class Program
{
    private static void Main(string[] args)
    {
        Console.WriteLine("Lecc16 - Act2 - Inciso 1");
        Console.WriteLine("Vianka Ajcholon / clave 1");

        //Arreglo - inicializar
        int[] edadPersona = new int[7];
        int cantidadPersMayores = 0;
        for (int i = 0; i < edadPersona.Length; i++)
        {
            Console.Write("Ingrese la edad" +(i+1)+":");
            edadPersona[i]=Convert.ToInt32(Console.ReadLine());
            if (edadPersona[i]>=18)
                cantidadPersMayores++;
        }

        //Mostrar los datos del arreglo
        Console.Clear();
        Console.WriteLine(" Las edades ingresadas son:");
        for (int i = 0; i < edadPersona.Length; i++)
        {
            Console.WriteLine(edadPersona[i] + " - ");
        }
        Console.WriteLine("La cantidad de personas Mayores de edad son:" + cantidadPersMayores);
    }
}
